# ─────────────────────────────────────────────────────
# Copy this to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────
# "openai"  → uses OpenAI API (needs OPENAI_API_KEY)
# "ollama"  → uses local Ollama container (free, no key needed)
LLM_PROVIDER=openai

# ── OpenAI (required if LLM_PROVIDER=openai) ─────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Ollama (required if LLM_PROVIDER=ollama) ─────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# ── ChromaDB ─────────────────────────────────────────
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=rag_documents

# ── Chunking (tune per your document types) ──────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────
TOP_K=5
RERANK_CANDIDATES=20
MIN_SCORE_THRESHOLD=0.45

# ── Upload limits ─────────────────────────────────────
MAX_FILE_SIZE_MB=20
